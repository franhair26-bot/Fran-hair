{
  "entities": {
    "client": {
      "title": "Client",
      "description": "Gerenciamento de clientes Fran Hair",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "phone", "email", "createdAt"]
    },
    "service": {
      "title": "Service",
      "description": "Catálogo de procedimentos disponíveis",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "durationMin": { "type": "integer" },
        "price": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "durationMin", "price", "category"]
    },
    "appointment": {
      "title": "Appointment",
      "description": "Agendamentos de serviços",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "clientPhone": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pendente", "confirmado", "concluido", "cancelado"] },
        "price": { "type": "number" },
        "notified": { "type": "boolean" },
        "professional": { "type": "string" }
      },
      "required": ["clientId", "clientName", "clientPhone", "serviceId", "serviceName", "date", "time", "status", "price", "notified", "professional"]
    },
    "product": {
      "title": "Product",
      "description": "Lista de suprimentos cosméticos e estoque",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "integer" },
        "minQuantity": { "type": "integer" },
        "priceCost": { "type": "number" },
        "priceSell": { "type": "number" },
        "lastRestocked": { "type": "string" }
      },
      "required": ["name", "brand", "category", "quantity", "minQuantity", "priceCost", "priceSell", "lastRestocked"]
    },
    "transaction": {
      "title": "Transaction",
      "description": "Balanço Geral de Movimentações Financeiras",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["receita", "despesa"] },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "appointmentId": { "type": "string" }
      },
      "required": ["type", "description", "amount", "date", "category"]
    },
    "notificationSetting": {
      "title": "NotificationSetting",
      "description": "Modelos de mensagens e templates de lembretes",
      "type": "object",
      "properties": {
        "timeBeforeHours": { "type": "integer" },
        "channel": { "type": "string" },
        "template": { "type": "string" },
        "isActive": { "type": "boolean" }
      },
      "required": ["timeBeforeHours", "channel", "template", "isActive"]
    },
    "professional": {
      "title": "Professional",
      "description": "Equipe de profissionais Fran Hair",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name", "role", "phone", "email"]
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": "client",
      "description": "Ficha de Clientes"
    },
    "/services/{serviceId}": {
      "schema": "service",
      "description": "Procedimentos e Preços"
    },
    "/appointments/{appointmentId}": {
      "schema": "appointment",
      "description": "Fila de Atendimento e Agenda"
    },
    "/products/{productId}": {
      "schema": "product",
      "description": "Estoque Cosmético"
    },
    "/transactions/{transactionId}": {
      "schema": "transaction",
      "description": "Fluxo de Caixa"
    },
    "/notificationSettings/{settingId}": {
      "schema": "notificationSetting",
      "description": "Configurações de Alertas"
    },
    "/professionals/{professionalId}": {
      "schema": "professional",
      "description": "Lista de Profissionais do Salão"
    }
  }
}
