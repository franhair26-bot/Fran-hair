rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions (Phase 3 & 4)
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints (The "Anti-Update-Gap")
    function isValidClient(data) {
      return (data.keys().size() == 6 || data.keys().size() == 7)
        && data.keys().hasAll(['name', 'phone', 'email', 'notes', 'createdAt', 'userId'])
        && (!data.keys().hasAll(['id']) || data.id is string)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.phone is string && data.phone.size() <= 25
        && data.email is string && data.email.size() <= 100
        && data.notes is string && data.notes.size() <= 2000
        && data.createdAt is string && data.createdAt.size() <= 50
        && data.userId == request.auth.uid;
    }

    function isValidService(data) {
      return (data.keys().size() == 5 || data.keys().size() == 6)
        && data.keys().hasAll(['name', 'durationMin', 'price', 'category', 'userId'])
        && (!data.keys().hasAll(['id']) || data.id is string)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.durationMin is int && data.durationMin >= 0 && data.durationMin <= 1440
        && (data.price is int || data.price is float) && data.price >= 0.0
        && data.category is string && data.category.size() <= 50
        && data.userId == request.auth.uid;
    }

    function isValidAppointment(data) {
      return (data.keys().size() == 12 || data.keys().size() == 13)
        && data.keys().hasAll(['clientId', 'clientName', 'clientPhone', 'serviceId', 'serviceName', 'date', 'time', 'status', 'price', 'notified', 'professional', 'userId'])
        && (!data.keys().hasAll(['id']) || data.id is string)
        && data.clientId is string && data.clientId.size() <= 128
        && data.clientName is string && data.clientName.size() <= 100
        && data.clientPhone is string && data.clientPhone.size() <= 25
        && data.serviceId is string && data.serviceId.size() <= 128
        && data.serviceName is string && data.serviceName.size() <= 100
        && data.date is string && data.date.size() <= 20
        && data.time is string && data.time.size() <= 10
        && data.status is string && (data.status == 'pendente' || data.status == 'confirmado' || data.status == 'concluido' || data.status == 'cancelado')
        && (data.price is int || data.price is float) && data.price >= 0.0
        && data.notified is bool
        && data.professional is string && data.professional.size() <= 100
        && data.userId == request.auth.uid;
    }

    function isValidProduct(data) {
      return (data.keys().size() == 9 || data.keys().size() == 10)
        && data.keys().hasAll(['name', 'brand', 'category', 'quantity', 'minQuantity', 'priceCost', 'priceSell', 'lastRestocked', 'userId'])
        && (!data.keys().hasAll(['id']) || data.id is string)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.brand is string && data.brand.size() <= 100
        && data.category is string && data.category.size() <= 100
        && data.quantity is int && data.quantity >= 0
        && data.minQuantity is int && data.minQuantity >= 0
        && (data.priceCost is int || data.priceCost is float) && data.priceCost >= 0.0
        && (data.priceSell is int || data.priceSell is float) && data.priceSell >= 0.0
        && data.lastRestocked is string && data.lastRestocked.size() <= 50
        && data.userId == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'description', 'amount', 'date', 'category', 'userId'])
        && (data.keys().size() >= 6 && data.keys().size() <= 8)
        && (!data.keys().hasAll(['id']) || data.id is string)
        && data.type is string && (data.type == 'receita' || data.type == 'despesa')
        && data.description is string && data.description.size() <= 200
        && (data.amount is int || data.amount is float) && data.amount >= 0.0
        && data.date is string && data.date.size() <= 20
        && data.category is string && data.category.size() <= 100
        && (!data.keys().hasAll(['appointmentId']) || data.appointmentId is string)
        && data.userId == request.auth.uid;
    }

    function isValidNotificationSetting(data) {
      return (data.keys().size() == 5 || data.keys().size() == 6)
        && data.keys().hasAll(['timeBeforeHours', 'channel', 'template', 'isActive', 'userId'])
        && (!data.keys().hasAll(['id']) || data.id is string)
        && data.timeBeforeHours is int && data.timeBeforeHours >= 0
        && data.channel is string && data.channel.size() <= 50
        && data.template is string && data.template.size() <= 1000
        && data.isActive is bool
        && data.userId == request.auth.uid;
    }

    function isValidProfessional(data) {
      return (data.keys().size() == 6 || data.keys().size() == 7)
        && data.keys().hasAll(['name', 'role', 'phone', 'email', 'color', 'userId'])
        && (!data.keys().hasAll(['id']) || data.id is string)
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.role is string && data.role.size() <= 100
        && data.phone is string && data.phone.size() <= 25
        && data.email is string && data.email.size() <= 100
        && data.color is string && data.color.size() <= 20
        && data.userId == request.auth.uid;
    }

    // Clients Collection Routing
    match /clients/{clientId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(clientId) && isValidClient(incoming());
      allow update: if isSignedIn() && isValidId(clientId) && isOwner(existing()) && isValidClient(incoming())
                       && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Services Collection Routing
    match /services/{serviceId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(serviceId) && isValidService(incoming());
      allow update: if isSignedIn() && isValidId(serviceId) && isOwner(existing()) && isValidService(incoming())
                       && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Appointments Collection Routing
    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(appointmentId) && isValidAppointment(incoming());
      allow update: if isSignedIn() && isValidId(appointmentId) && isOwner(existing()) && isValidAppointment(incoming())
                       && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Products Collection Routing
    match /products/{productId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isSignedIn() && isValidId(productId) && isOwner(existing()) && isValidProduct(incoming())
                       && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Transactions Collection Routing
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidId(transactionId) && isOwner(existing()) && isValidTransaction(incoming())
                       && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // NotificationSettings Collection Routing
    match /notificationSettings/{settingId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(settingId) && isValidNotificationSetting(incoming());
      allow update: if isSignedIn() && isValidId(settingId) && isOwner(existing()) && isValidNotificationSetting(incoming())
                       && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }

    // Professionals Collection Routing
    match /professionals/{professionalId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(professionalId) && isValidProfessional(incoming());
      allow update: if isSignedIn() && isValidId(professionalId) && isOwner(existing()) && isValidProfessional(incoming())
                       && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing());
    }
  }
}
